# ==============================================
# Sarray Forge - Deployment Configuration
# Copy this to .env in the project root
# ==============================================

# Server connection for deploy.sh
DEPLOY_HOST=forge.sarray.de
DEPLOY_USER=root
DEPLOY_PATH=/opt/sarray-forge

# ==============================================
# The following are set on the SERVER via systemd
# (see sarray-forge.service)
# ==============================================
# PORT=8080
# DATABASE_PATH=/opt/sarray-forge/data/sarray-forge.db
# STATIC_DIR=/opt/sarray-forge/web/dist
# MIGRATIONS_DIR=/opt/sarray-forge/migrations
# UPLOADS_DIR=/opt/sarray-forge/data/releases
